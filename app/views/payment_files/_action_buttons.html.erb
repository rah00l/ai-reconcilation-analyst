<div class="flex gap-2">
  <% if file.status_new? || file.status_ready? %>
    <%= link_to 'Parse', '#', class: 'px-3 py-1 bg-blue-500 hover:bg-blue-600 text-white text-sm rounded font-medium' %>
  <% elsif file.status_parsed? || file.status_partial_reconciled? %>
    <%= link_to 'Display', display_payment_file_path(file), class: 'px-3 py-1 bg-green-500 hover:bg-green-600 text-white text-sm rounded font-medium' %>
  <% elsif file.status_full_reconciled? %>
    <%= link_to 'Summary', summary_payment_file_path(file), class: 'px-3 py-1 bg-green-500 hover:bg-green-600 text-white text-sm rounded font-medium' %>
  <% end %>
  
  <% unless file.status_processing? %>
    <%= link_to 'Remove', '#', class: 'px-3 py-1 bg-red-500 hover:bg-red-600 text-white text-sm rounded font-medium' %>
  <% end %>
</div>