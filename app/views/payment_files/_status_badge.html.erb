<% 
  color_class = case status
  when 'new' then 'bg-gray-100 text-gray-800'
  when 'ready' then 'bg-yellow-100 text-yellow-800'
  when 'processing' then 'bg-blue-100 text-blue-800'
  when 'parsed' then 'bg-green-100 text-green-800'
  when 'partial_reconciled' then 'bg-orange-100 text-orange-800'
  when 'full_reconciled' then 'bg-green-200 text-green-900'
  else 'bg-gray-100 text-gray-800'
  end
%>
<span class="px-3 py-1 rounded-full text-xs font-semibold <%= color_class %>">
  <%= status.humanize %>
</span>