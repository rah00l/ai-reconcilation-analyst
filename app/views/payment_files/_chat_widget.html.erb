<div id="chat-widget" class="fixed bottom-4 right-4 w-96 h-[500px] bg-white rounded-lg shadow-2xl flex flex-col z-50 border border-gray-200" style="
    height: 602px;
    width: 452px;
">
  <!-- Header -->
  <div class="bg-gradient-to-r from-blue-600 to-blue-700 text-white p-4 rounded-t-lg flex justify-between items-center">
    <div>
      <h3 class="font-bold text-lg">AI Analyst Assistant</h3>
      <p class="text-xs text-blue-100">Ask about reconciliation</p>
    </div>
    <div class="flex gap-2">
      <button id="chat-minimize" class="text-white hover:text-blue-200 text-xl transition">−</button>
      <button id="chat-close" class="text-white hover:text-blue-200 text-xl transition">✕</button>
    </div>
  </div>

  <!-- Messages Container -->
  <div id="chat-messages" class="flex-1 overflow-y-auto p-4 space-y-3 bg-gray-50">
    <!-- Initial welcome message -->
    <div class="flex justify-start">
      <div class="bg-white text-gray-800 p-3 rounded-lg max-w-sm shadow-sm border border-gray-200">
        <p class="text-sm font-medium text-gray-700">Welcome! 👋</p>
        <p class="text-xs text-gray-600 mt-2">I can help you understand reconciliation statuses, errors, settlements, and more. What would you like to know?</p>
      </div>
    </div>
  </div>

  <!-- Loading indicator (hidden by default) -->
  <div id="chat-loading" class="hidden px-4 py-2 text-center">
    <div class="flex items-center justify-center gap-2">
      <div class="w-2 h-2 bg-blue-500 rounded-full animate-bounce"></div>
      <div class="w-2 h-2 bg-blue-500 rounded-full animate-bounce" style="animation-delay: 0.2s"></div>
      <div class="w-2 h-2 bg-blue-500 rounded-full animate-bounce" style="animation-delay: 0.4s"></div>
    </div>
  </div>

  <!-- Input Section -->
  <div class="p-4 border-t bg-white rounded-b-lg">
    <form id="chat-form" class="flex gap-2">
      <input
        type="text"
        id="chat-input"
        placeholder="Type your question..."
        class="flex-1 px-3 py-2 border border-gray-300 rounded text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500"
        autocomplete="off"
      />
      <button
        type="submit"
        id="chat-send"
        class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded text-sm font-medium transition"
      >
        Send
      </button>
    </form>
  </div>
</div>

<!-- Minimized Widget -->
<div id="chat-widget-minimized" class="hidden fixed bottom-4 right-4 bg-gradient-to-r from-blue-600 to-blue-700 text-white rounded-lg shadow-2xl p-3 z-50 cursor-pointer hover:shadow-xl transition w-24 text-center">
  <div onclick="expandChat()">
    <p class="text-xl">💬</p>
    <p class="text-xs font-semibold whitespace-nowrap">AI Asst</p>
  </div>
  <button id="chat-minimize-close" class="absolute top-1 right-1 text-white hover:text-blue-100 text-sm" onclick="event.stopPropagation(); closeChat()">✕</button>
</div>

<script>
  // ============================================
  // GLOBAL UTILITY FUNCTIONS
  // ============================================

  /**
   * Escape HTML to prevent XSS attacks
   * Converts special characters to HTML entities
   */
  function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  /**
   * Generate unique session ID for multi-turn conversations
   * Format: session_timestamp_randomHex
   */
  function generateSessionId() {
    const timestamp = Date.now();
    const random = Math.random().toString(36).substr(2, 9);
    return `session_${timestamp}_${random}`;
  }

  // ============================================
  // UI CONTROL FUNCTIONS
  // ============================================

  /**
   * Minimize chat widget to bottom bar
   */
  function minimizeChat() {
    const chatWidget = document.getElementById('chat-widget');
    const chatMinimized = document.getElementById('chat-widget-minimized');
    chatWidget.style.display = 'none';
    chatMinimized.classList.remove('hidden');
  }

  /**
   * Expand minimized chat widget
   */
  function expandChat() {
    const chatWidget = document.getElementById('chat-widget');
    const chatMinimized = document.getElementById('chat-widget-minimized');
    chatMinimized.classList.add('hidden');
    chatWidget.style.display = 'flex';
    // Focus input for better UX
    const input = document.getElementById('chat-input');
    if (input) input.focus();
  }

  /**
   * Close chat widget completely
   */
  function closeChat() {
    const chatWidget = document.getElementById('chat-widget');
    const chatMinimized = document.getElementById('chat-widget-minimized');
    chatWidget.style.display = 'none';
    chatMinimized.classList.add('hidden');
  }

  // ============================================
  // INITIALIZATION
  // ============================================

  document.addEventListener('DOMContentLoaded', function() {
    // ========================================
    // DOM ELEMENTS
    // ========================================
    const chatForm = document.getElementById('chat-form');
    const chatInput = document.getElementById('chat-input');
    const chatMessages = document.getElementById('chat-messages');
    const chatLoading = document.getElementById('chat-loading');
    const chatMinimizeBtn = document.getElementById('chat-minimize');
    const chatCloseBtn = document.getElementById('chat-close');

    // ========================================
    // STATE
    // ========================================
    let currentSessionId = null;

    // ========================================
    // HELPER FUNCTIONS
    // ========================================

    /**
     * Get CSRF token from meta tag
     * Required for Rails security (CSRF protection)
     * @returns {string} CSRF token or empty string
     */
    function getCsrfToken() {
      const token = document.querySelector('meta[name="csrf-token"]')?.content;
      if (!token) {
        console.warn('CSRF token not found - Rails CSRF protection may not work');
      }
      return token || '';
    }

    /**
     * Extract file_id from current page URL
     * Supports multiple URL formats:
     * - /payment_files/123
     * - /payment_files/123/display
     * - /payment_files/123/show
     * @returns {string|null} File ID or null if not found
     */
    function getFileId() {
      // Try URL search params first
      const urlParams = new URLSearchParams(window.location.search);
      const fileIdFromUrl = urlParams.get('file_id');
      if (fileIdFromUrl) return fileIdFromUrl;

      // Try data attribute
      const fileIdFromAttr = document.querySelector('[data-file-id]')?.dataset.fileId;
      if (fileIdFromAttr) return fileIdFromAttr;

      // Try extracting from pathname
      const pathMatch = window.location.pathname.match(/\/payment_files\/(\d+)/);
      return pathMatch ? pathMatch[1] : null;
    }

    /**
     * Add message to chat
     * @param {string} text - Message text or HTML
     * @param {string} sender - 'user' or 'assistant'
     * @param {boolean} isHtml - If true, treat text as HTML; if false, escape it
     */
    function addMessage(text, sender, isHtml = false) {
      if (!text) return;

      const messageEl = document.createElement('div');
      messageEl.className = sender === 'user' ? 'flex justify-end' : 'flex justify-start';

      const bubbleEl = document.createElement('div');

      if (sender === 'user') {
        // User message: blue background, white text
        bubbleEl.className = 'bg-blue-600 text-white p-3 rounded-lg max-w-sm shadow-sm';
      } else {
        // Assistant message: white background, gray text
        bubbleEl.className = 'bg-white text-gray-800 p-3 rounded-lg max-w-sm shadow-sm border border-gray-200';
      }

      // Handle HTML vs plain text
      if (isHtml) {
        // If isHtml is true, use innerHTML (for formatted responses)
        bubbleEl.innerHTML = text;
      } else {
        // If isHtml is false, escape and use textContent (for plain text)
        bubbleEl.innerHTML = `<p class="text-sm">${escapeHtml(text)}</p>`;
      }

      messageEl.appendChild(bubbleEl);
      chatMessages.appendChild(messageEl);

      // Auto-scroll to bottom
      chatMessages.scrollTop = chatMessages.scrollHeight;
    }

    /**
     * Add follow-up suggestion buttons
     * These are clickable buttons that populate the input and send
     * @param {array} followUps - Array of suggestion strings
     */
    function addFollowUpButtons(followUps) {
      if (!followUps || followUps.length === 0) return;

      const followUpEl = document.createElement('div');
      followUpEl.className = 'text-xs text-gray-500 px-3 py-2 space-y-1';
      followUpEl.innerHTML = '<p class="font-medium mb-2 text-gray-600">💡 Try asking:</p>';

      followUps.forEach(followUp => {
        const btn = document.createElement('button');
        btn.className = 'block w-full text-left text-blue-600 hover:text-blue-800 hover:bg-blue-50 px-2 py-1 rounded text-xs cursor-pointer transition';
        btn.textContent = followUp;
        btn.type = 'button';

        btn.onclick = (e) => {
          e.preventDefault();
          chatInput.value = followUp;
          chatForm.dispatchEvent(new Event('submit'));
        };

        followUpEl.appendChild(btn);
      });

      chatMessages.appendChild(followUpEl);
      chatMessages.scrollTop = chatMessages.scrollHeight;
    }

    // ========================================
    // FORM SUBMISSION HANDLER
    // ========================================

    chatForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Get question from input
      const question = chatInput.value.trim();
      if (!question) return;

      // Generate session ID on first request
      if (!currentSessionId) {
        currentSessionId = generateSessionId();
      }

      // Get optional file_id
      const fileId = getFileId();

      // Add user message to chat
      addMessage(question, 'user', false);
      chatInput.value = '';
      chatInput.focus();

      // Show loading indicator
      chatLoading.classList.remove('hidden');

      try {
        // ====================================
        // BUILD REQUEST PAYLOAD
        // ====================================

        const payload = {
          question: question,
          session_id: currentSessionId
        };

        // Add file_id only if available
        if (fileId) {
          payload.file_id = fileId;
        }

        // ====================================
        // FETCH FROM CONTROLLER
        // ====================================

        const csrfToken = getCsrfToken();

        const response = await fetch('/chat/analyze', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': csrfToken
          },
          body: JSON.stringify(payload)
        });

        // Hide loading indicator
        chatLoading.classList.add('hidden');

        // ====================================
        // HANDLE HTTP ERRORS
        // ====================================

        if (!response.ok) {
          console.error(`HTTP ${response.status}:`, response.statusText);
          addMessage('Server error. Please try again.', 'assistant', false);
          return;
        }

        // ====================================
        // PARSE RESPONSE
        // ====================================

        const data = await response.json();

        if (!data) {
          addMessage('No response received. Please try again.', 'assistant', false);
          return;
        }

        // ====================================
        // DISPLAY FORMATTED RESPONSE
        // ====================================

        console.log('=== CHAT RESPONSE DEBUG ===');
        console.log('Response status:', data.status);
        console.log('Full response object:', data);
        console.log('Has formatted_html:', !!data.formatted_html);
        console.log('formatted_html length:', data.formatted_html ? data.formatted_html.length : 'N/A');
        console.log('Has explanation:', !!data.explanation);
        console.log('=== END DEBUG ===');

        // Validate response structure
        if (!data || typeof data !== 'object') {
          console.error('Invalid response structure:', data);
          addMessage('Invalid response from server.', 'assistant', false);
          return;
        }

        // Key change: Use formatted_html from controller
        let responseAdded = false;

        if (data.formatted_html && data.formatted_html.trim()) {
          // formatted_html is already beautiful HTML from helper
          console.log('Adding formatted HTML response');
          addMessage(data.formatted_html, 'assistant', true);
          responseAdded = true;
        } else if (data.explanation && data.explanation.trim()) {
          // Fallback to explanation if no formatted HTML
          console.log('Adding explanation fallback');
          addMessage(data.explanation, 'assistant', false);
          responseAdded = true;
        } else {
          // Last resort fallback
          console.warn('No formatted_html or explanation found');
          console.warn('Response keys:', Object.keys(data));
          addMessage('No response content available.', 'assistant', false);
          responseAdded = true;
        }

        if (!responseAdded) {
          console.error('Failed to add response');
        }

        // ====================================
        // SHOW FOLLOW-UP SUGGESTIONS
        // ====================================

        if (data.follow_ups && Array.isArray(data.follow_ups) && data.follow_ups.length > 0) {
          addFollowUpButtons(data.follow_ups);
        }

        // ====================================
        // UPDATE SESSION ID FOR FOLLOW-UPS
        // ====================================

        if (data.session_id) {
          currentSessionId = data.session_id;
        }

      } catch (error) {
        // Hide loading indicator
        chatLoading.classList.add('hidden');

        // Display error message
        console.error('Chat error:', error);
        addMessage(`Network error: ${error.message}`, 'assistant', false);
      }
    });

    // ========================================
    // BUTTON EVENT LISTENERS
    // ========================================

    chatMinimizeBtn.addEventListener('click', minimizeChat);
    chatCloseBtn.addEventListener('click', closeChat);

    // Optional: Auto-focus input on load
    chatInput.focus();
  });
</script>