<div class="min-h-screen bg-gray-50">
  <div class="container mx-auto px-4 py-8">
    <!-- PROFESSIONAL HORIZONTAL HEADER -->
    <%= render 'shared/header' %>

    <!-- Reconciled Data Summary Table -->
    <div class="bg-white rounded-lg shadow-lg overflow-hidden mb-8">
      <div class="p-4 bg-gray-100 border-b">
        <h2 class="text-lg font-bold text-gray-900">Reconciled Data Summary</h2>
      </div>
      
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="bg-gray-200 border-b-2 border-gray-400">
              <th class="px-4 py-3 text-left font-bold text-gray-900">MID</th>
              <th class="px-4 py-3 text-left font-bold text-gray-900">Merchant Name</th>
              <th class="px-4 py-3 text-left font-bold text-gray-900">Transaction Type</th>
              <th class="px-4 py-3 text-right font-bold text-gray-900">Initial Commission</th>
              <th class="px-4 py-3 text-right font-bold text-gray-900">Consumer</th>
              <th class="px-4 py-3 text-right font-bold text-gray-900">Final Commission</th>
              <th class="px-4 py-3 text-right font-bold text-gray-900">Partner Commission</th>
              <th class="px-4 py-3 text-right font-bold text-gray-900">Internal Commission</th>
              <th class="px-4 py-3 text-right font-bold text-gray-900">Transaction Locked</th>
            </tr>
          </thead>
          <tbody>
            <!-- Bonus Transaction (if exists) -->
            <tr class="border-b hover:bg-gray-50">
              <td class="px-4 py-3 text-gray-900"></td>
              <td class="px-4 py-3 text-gray-900"></td>
              <td class="px-4 py-3 text-gray-900">BONUS</td>
              <td class="px-4 py-3 text-right text-gray-900">189.00</td>
              <td class="px-4 py-3 text-right text-gray-900">0.00</td>
              <td class="px-4 py-3 text-right text-gray-900">189.00</td>
              <td class="px-4 py-3 text-right text-gray-900">94.50</td>
              <td class="px-4 py-3 text-right text-gray-900">94.50</td>
              <td class="px-4 py-3 text-right text-gray-900">1</td>
            </tr>

            <!-- Merchant Transactions -->
            <tr class="border-b hover:bg-gray-50">
              <td class="px-4 py-3 text-gray-900">54719</td>
              <td class="px-4 py-3 text-gray-900">Ipmobile</td>
              <td class="px-4 py-3 text-gray-900">TRANSACTION</td>
              <td class="px-4 py-3 text-right text-gray-900">185.15</td>
              <td class="px-4 py-3 text-right text-gray-900">185.15</td>
              <td class="px-4 py-3 text-right text-gray-900">185.15</td>
              <td class="px-4 py-3 text-right text-gray-900">76.65</td>
              <td class="px-4 py-3 text-right text-gray-900">0.00</td>
              <td class="px-4 py-3 text-right text-gray-900">30</td>
            </tr>

            <tr class="border-b hover:bg-gray-50">
              <td class="px-4 py-3 text-gray-900">32671</td>
              <td class="px-4 py-3 text-gray-900">Bench</td>
              <td class="px-4 py-3 text-gray-900">TRANSACTION</td>
              <td class="px-4 py-3 text-right text-gray-900">7.33</td>
              <td class="px-4 py-3 text-right text-gray-900">13.07</td>
              <td class="px-4 py-3 text-right text-gray-900">7.33</td>
              <td class="px-4 py-3 text-right text-gray-900">-5.74</td>
              <td class="px-4 py-3 text-right text-gray-900">0.00</td>
              <td class="px-4 py-3 text-right text-gray-900">3</td>
            </tr>

            <tr class="border-b hover:bg-gray-50">
              <td class="px-4 py-3 text-gray-900">32681</td>
              <td class="px-4 py-3 text-gray-900">wegottickets.com</td>
              <td class="px-4 py-3 text-gray-900">TRANSACTION</td>
              <td class="px-4 py-3 text-right text-gray-900">0.81</td>
              <td class="px-4 py-3 text-right text-gray-900">11.51</td>
              <td class="px-4 py-3 text-right text-gray-900">0.81</td>
              <td class="px-4 py-3 text-right text-gray-900">-6.56</td>
              <td class="px-4 py-3 text-right text-gray-900">0.00</td>
              <td class="px-4 py-3 text-right text-gray-900">5</td>
            </tr>

            <!-- Totals Row -->
            <tr class="bg-gray-200 border-b-2 border-gray-400 font-bold">
              <td class="px-4 py-3 text-gray-900">Total</td>
              <td class="px-4 py-3 text-gray-900"></td>
              <td class="px-4 py-3 text-gray-900"></td>
