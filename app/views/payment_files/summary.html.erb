    </div>

    <!-- Download Buttons for Reconciled Data -->
    <div class="mb-8 flex gap-4">
      <button class="px-6 py-2 bg-blue-500 hover:bg-blue-600 text-white rounded font-medium">
        DOWNLOAD SUMMARY
      </button>
      <button class="px-6 py-2 bg-blue-500 hover:bg-blue-600 text-white rounded font-medium">
        DOWNLOAD TRANSACTIONS
      </button>
    </div>

    <!-- Unmatched Data Summary Table -->
    <div class="bg-white rounded-lg shadow-lg overflow-hidden mb-8">
      <div class="p-4 bg-gray-100 border-b">
        <h2 class="text-lg font-bold text-gray-900">Unmatched Data Summary</h2>
      </div>
      
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="bg-gray-200 border-b-2 border-gray-400">
              <th class="px-4 py-3 text-left font-bold text-gray-900">MID</th>
              <th class="px-4 py-3 text-left font-bold text-gray-900">Merchant Name</th>
              <th class="px-4 py-3 text-right font-bold text-gray-900">Commission</th>
              <th class="px-4 py-3 text-right font-bold text-gray-900">Transaction Locked</th>
            </tr>
          </thead>
          <tbody>
            <!-- Totals Row (No unmatched data in this example) -->
            <tr class="bg-gray-100 border-b-2 border-gray-400 font-bold">
              <td class="px-4 py-3 text-gray-900">Total</td>
              <td class="px-4 py-3 text-gray-900"></td>
              <td class="px-4 py-3 text-right text-gray-900">0.00</td>
              <td class="px-4 py-3 text-right text-gray-900">0</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Download Buttons for Unmatched Data -->
    <div class="mb-8 flex gap-4">
      <button class="px-6 py-2 bg-blue-500 hover:bg-blue-600 text-white rounded font-medium">
        DOWNLOAD SUMMARY
      </button>
      <button class="px-6 py-2 bg-blue-500 hover:bg-blue-600 text-white rounded font-medium">
        DOWNLOAD TRANSACTIONS
      </button>
    </div>

    <!-- Navigation Buttons -->
    <div class="flex gap-4">
      <%= link_to '← Back: Review', display_payment_file_path(@payment_file), class: 'px-4 py-2 bg-blue-500 hover:bg-blue-600 text-white rounded font-medium' %>
      <%= link_to '← Back to Files', payment_files_path, class: 'px-4 py-2 bg-gray-500 hover:bg-gray-600 text-white rounded font-medium' %>
    </div>
  </div>
</div>