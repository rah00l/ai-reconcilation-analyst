# Rails Configuration
RAILS_ENV=development
RAILS_LOG_TO_STDOUT=true

# Engine Configuration
# Local Docker Compose: use engine service
ENGINE_URL=http://engine:4567

# For production (override):
# ENGINE_URL=https://ai-analyst-engine.onrender.com

# Engine Timeout
ENGINE_TIMEOUT=30

# For local testing, these values should work:
DATABASE_URL=postgresql://...

HTTP_AUTH_USER=test.user
HTTP_AUTH_PASSWORD=Password123

SECRET_KEY_BASE=change-me
RAILS_MASTER_KEY=change-me